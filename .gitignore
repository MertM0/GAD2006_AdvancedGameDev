# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
**/SourceArt/**/*.png
**/SourceArt/**/*.tga

# Binary Files
**/Binaries/*
**/Plugins/**/Binaries/*

# Builds
**/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!**/Build/*/
**/Build/*/**
!**/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!**/Build/**/*.ico

# Built data for maps
**/*_BuiltData.uasset

# Configuration files generated by the Editor
**/Saved/*

# Compiled source files for the engine to use
**/Intermediate/*
**/Plugins/**/Intermediate/*

# Cache files for the editor to use
**/DerivedDataCache/*

.editorconfig
.vsconfig
.gitattributes

# Content Folders
**/Content/__ExternalActors__
**/Content/__ExternalObjects__
**/Content/Characters
**/Content/Collections
**/Content/Developers
**/Content/Input
**/Content/LevelPrototyping

# Labwork2 Content
**/Labwork2/Content/Materials
**/Labwork2/Content/Meshes
**/Labwork2/Content/UI

# Labwork3 Content
**/Labwork3/Content/Materials
**/Labwork3/Content/Textures
**/Labwork3/Content/Models
**/Labwork3/Content/UI